# ScriptRunner Configuration

# GitHub repository with Python scripts
SCRIPTS_REPO_URL=https://github.com/YOUR_USERNAME/python-scripts

# GitHub repository with kill-switch config
KILL_SWITCH_REPO=https://github.com/YOUR_USERNAME/script-runner-config

# (Optional) GitHub API token for private repos
GITHUB_TOKEN=your_github_token_here

# (Optional) Logging level: debug, info, warn, error
LOG_LEVEL=info

# (Optional) Python version to use
PYTHON_VERSION=3.12.9

# (Optional) Custom scripts directory
SCRIPTS_DIR=./scripts

# (Optional) GitHub repo used for release-page fallback checks (owner/repo)
SR_RELEASES_REPO=PatrykEmilLibert/script-runner

# (Optional) Tauri updater static JSON endpoint (latest.json)
SR_UPDATER_ENDPOINT=https://github.com/PatrykEmilLibert/script-runner/releases/latest/download/latest.json

# (Required for in-app install) Tauri updater public key used to verify signed artifacts
SR_UPDATER_PUBKEY=
