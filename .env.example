# ScriptRunner Configuration

# GitHub repository with Python scripts
SCRIPTS_REPO_URL=https://github.com/YOUR_USERNAME/python-scripts

# GitHub repository with kill-switch config
KILL_SWITCH_REPO=https://github.com/YOUR_USERNAME/script-runner-config

# (Optional) GitHub API token for private repos
GITHUB_TOKEN=your_github_token_here

# (Optional) Admin key path (for enabling Admin Mode on this machine)
ADMIN_KEY_PATH=C:\\Users\\Public\\Desktop\\sr-admin.key

# (Optional) Logging level: debug, info, warn, error
LOG_LEVEL=info

# (Optional) Python version to use
PYTHON_VERSION=3.12.9

# (Optional) Custom scripts directory
SCRIPTS_DIR=./scripts
